rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: userId (uid)
    // Fields: uid, displayName, email, currency, createdAt
    //
    // Collection: transactions
    // Document ID: transactionId
    // Fields: userId, amount, type, category, description, date, isAiCategorized
    //
    // Collection: budgets
    // Document ID: budgetId
    // Fields: userId, category, limit, month
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidTransaction(data) {
      return data.userId == request.auth.uid &&
             data.amount is number &&
             data.type in ['income', 'expense'] &&
             data.category is string && data.category.size() < 100 &&
             data.date is string;
    }

    function isValidBudget(data) {
      return data.userId == request.auth.uid &&
             data.category is string && data.category.size() < 100 &&
             data.limit is number && data.limit >= 0 &&
             data.month is string;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidTransaction(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /budgets/{budgetId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidBudget(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidBudget(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }
  }
}
