rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: userId (uid)
    // Fields: uid, displayName, email, currency, createdAt
    //
    // Collection: transactions
    // Document ID: transactionId
    // Fields: userId, amount, type, category, description, date, isAiCategorized
    //
    // Collection: budgets
    // Document ID: budgetId
    // Fields: userId, category, limit, month
    //
    // Collection: savingsGoals
    // Document ID: goalId
    // Fields: userId, title, targetAmount, currentAmount, deadline, category, createdAt
    //
    // Collection: investments
    // Document ID: investmentId
    // Fields: userId, name, category, amount, expectedReturnRate, createdAt
    //
    // Collection: recurringTransactions
    // Document ID: recurringId
    // Fields: userId, amount, type, category, description, frequency, startDate, nextDate, createdAt
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidTransaction(data) {
      return data.userId == request.auth.uid &&
             data.amount is number &&
             data.type in ['income', 'expense'] &&
             data.category is string && data.category.size() < 100 &&
             data.date is string;
    }

    function isValidBudget(data) {
      return data.userId == request.auth.uid &&
             data.category is string && data.category.size() < 100 &&
             data.limit is number && data.limit >= 0 &&
             data.month is string;
    }

    function isValidSavingsGoal(data) {
      return data.userId == request.auth.uid &&
             data.title is string && data.title.size() < 100 &&
             data.targetAmount is number && data.targetAmount > 0 &&
             data.currentAmount is number && data.currentAmount >= 0 &&
             data.deadline is string &&
             data.category is string && data.category.size() < 100 &&
             data.createdAt is string;
    }

    function isValidInvestment(data) {
      return data.userId == request.auth.uid &&
             data.name is string && data.name.size() < 100 &&
             data.category is string && data.category.size() < 100 &&
             data.amount is number && data.amount >= 0 &&
             data.expectedReturnRate is number &&
             data.createdAt is string;
    }

    function isValidRecurring(data) {
      return data.userId == request.auth.uid &&
             data.amount is number &&
             data.type in ['income', 'expense'] &&
             data.category is string && data.category.size() < 100 &&
             data.frequency in ['daily', 'weekly', 'monthly', 'yearly'] &&
             data.startDate is string &&
             data.nextDate is string &&
             data.createdAt is string;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidTransaction(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /budgets/{budgetId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidBudget(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidBudget(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /savingsGoals/{goalId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidSavingsGoal(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidSavingsGoal(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /investments/{investmentId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidInvestment(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidInvestment(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /recurringTransactions/{recurringId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidRecurring(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidRecurring(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }
  }
}
